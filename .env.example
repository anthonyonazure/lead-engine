ANTHROPIC_API_KEY=sk-ant-...
LEAD_ENGINE_PORT=3001
LEAD_ENGINE_DB=./data/leads.db
LEAD_ENGINE_SCORE_MODEL=claude-haiku-4-5-20251001
LEAD_ENGINE_DRAFT_MODEL=claude-sonnet-4-6

# Auth — required for production. Generate with: openssl rand -base64 32
# Frontend reads VITE_LEAD_ENGINE_API_KEY at build time and sends it on every request.
LEAD_ENGINE_API_KEY=
VITE_LEAD_ENGINE_API_KEY=

# CORS allowlist (comma-separated origins). Empty = allow only localhost dev origin.
LEAD_ENGINE_WEB_ORIGIN=http://localhost:5173

# Twilio (optional — required only for real SMS sending and webhook verification)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# E.164 country prefixes allowed for outbound SMS (comma-separated, e.g. "+1,+44").
# Default blocks premium-rate / non-allowlisted destinations entirely.
TWILIO_ALLOWED_COUNTRIES=+1

# Postmark (optional — required only for real email sending)
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_ADDRESS=
POSTMARK_REPLY_TO=

# Business profile (used in outreach drafting context)
BUSINESS_NAME=Your Services Business
BUSINESS_OWNER_NAME=Owner

# Twilio (optional — required only for real SMS sending)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Postmark (optional — required only for real email sending)
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_ADDRESS=
POSTMARK_REPLY_TO=

# Business profile (used in outreach drafting context)
BUSINESS_NAME=Your Services Business
BUSINESS_OWNER_NAME=Owner
